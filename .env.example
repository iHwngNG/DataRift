# ==============================================================================
# DATARIFT ENVIRONMENT VARIABLES CONFIGURATION (EXAMPLE TEMPLATE)
# ==============================================================================
# Copy this file to '.env' and fill in your actual values.
# DO NOT commit the '.env' file itself or any secrets to source control.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. RIOT API CONFIGURATION (riot_config.py)
# ------------------------------------------------------------------------------
# [REQUIRED] Your Riot Games API Key. Get one at: https://developer.riotgames.com/
# Example format: RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
RIOT_API_KEY=RGAPI-your-api-key-here

# Platform routing value (e.g., kr, na1, euw1, br1, jp1, la1, la2, oc1, ru, tr)
# Korea (kr) is default for competitive data collection
RIOT_PLATFORM=kr

# Regional routing value for match IDs/endpoints (e.g., asia, americas, europe, sea)
RIOT_REGION=asia

# API client request tuning
RIOT_MAX_RETRIES=5
RIOT_BACKOFF_FACTOR=1.0
RIOT_TIMEOUT=10

# Rate limits (default for dev key is 20 requests per second & 100 requests per 2 minutes)
# Set appropriately if using a production key
RIOT_RATE_LIMIT_PER_SEC=20
RIOT_RATE_LIMIT_PER_2MIN=100

# Base URL for Riot Data Dragon (static assets)
RIOT_DATA_DRAGON_BASE=https://ddragon.leagueoflegends.com

# ------------------------------------------------------------------------------
# 2. GOOGLE CLOUD STORAGE CONFIGURATION (gcs_config.py)
# ------------------------------------------------------------------------------
# GCS bucket names for raw (Bronze) and processed (Silver) data
GCS_BRONZE_BUCKET=datarift-bronze
GCS_SILVER_BUCKET=datarift-silver

# GCS object key path prefixes
GCS_LEAGUE_PREFIX=lol/league
GCS_MATCH_PREFIX=lol/match
GCS_STATIC_PREFIX=lol

# GCS multi-part upload chunk size in bytes (default: 8,388,608 bytes = 8 MiB)
GCS_CHUNK_BYTES=8388608

# ------------------------------------------------------------------------------
# 3. PIPELINE & INGESTION TUNING (pipeline_config.py)
# ------------------------------------------------------------------------------
# Batch size for queue processing and workers
PIPELINE_BATCH_SIZE=100
PIPELINE_MAX_WORKERS=4

# Target count of matches to retrieve per player
PIPELINE_MATCH_COUNT=20

# Pipeline request timeouts in seconds
PIPELINE_REQUEST_TIMEOUT=30

# Queue ID target (420 = 5v5 Ranked Solo queue)
PIPELINE_QUEUE_ID=420

# Comma-separated list of target Tiers to fetch
PIPELINE_TIERS=DIAMOND,PLATINUM

# Comma-separated list of target Divisions to fetch
PIPELINE_DIVISIONS=I,II,III,IV

# ------------------------------------------------------------------------------
# 4. APACHE ICEBERG & GCP CONFIGURATION (iceberg_config.py)
# ------------------------------------------------------------------------------
# GCP Project ID for resources and credentials
GCP_PROJECT_ID=datarift-demo-dev

# Apache Iceberg catalog specifications
ICEBERG_CATALOG_TYPE=rest
ICEBERG_CATALOG_URI=
ICEBERG_WAREHOUSE_URI=gs://datarift-silver/warehouse
ICEBERG_NAMESPACE=lol
ICEBERG_TABLE_PREFIX=raw_

# ------------------------------------------------------------------------------
# 5. LOGGING CONFIGURATION (logging_config.py)
# ------------------------------------------------------------------------------
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Set to true to output structured logs in JSON format (e.g., in production)
LOG_JSON=false

# Service name descriptor used in logs
LOG_SERVICE_NAME=datarift-ingestor

# Include timestamp in plain-text logs
LOG_INCLUDE_TIMESTAMP=true
